{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@api/domain/*": ["src/domain/*"],
      "@api/application/*": ["src/application/*"],
      "@api/infrastructure/*": ["src/infrastructure/*"],
      "@shared": ["../../shared/src/index.ts"],
      "@shared/*": ["../../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
